#!/usr/bin/env python3
"""系统级入口：把 cut_video.py 所在目录加入 PATH 后可直接调用"""
import sys
from pathlib import Path

# 找到 cut_video.py 所在目录（本文件与 cut_video.py 在同一目录）
HERE = Path(__file__).parent
CUT_VIDEO = HERE / "cut_video.py"

if not CUT_VIDEO.exists():
    print(f"❌ 找不到 cut_video.py: {CUT_VIDEO}")
    sys.exit(1)

# 传递所有参数给 cut_video.py
sys.argv[0] = str(CUT_VIDEO)
with open(CUT_VIDEO, encoding="utf-8") as f:
    code = compile(f.read(), CUT_VIDEO, "exec")
exec(code)
