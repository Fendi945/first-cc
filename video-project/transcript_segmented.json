{
  "segments": [
    {
      "index": 1,
      "text": "前两天我帮业主审了一套图"
    },
    {
      "index": 2,
      "text": "图纸报价8万"
    },
    {
      "index": 3,
      "text": "一看我就知道这预算不够"
    },
    {
      "index": 4,
      "text": "不是施工队黑"
    },
    {
      "index": 5,
      "text": "是图纸上埋了三个雷"
    },
    {
      "index": 6,
      "text": "今天拆给你看"
    },
    {
      "index": 7,
      "text": "设计师动动脑子"
    },
    {
      "index": 8,
      "text": "能帮你省下好几万"
    },
    {
      "index": 9,
      "text": "外行看图看什么"
    },
    {
      "index": 10,
      "text": "看效果图好不好看"
    },
    {
      "index": 11,
      "text": "我们看图看什么"
    },
    {
      "index": 12,
      "text": "看三年后哪里要改"
    },
    {
      "index": 13,
      "text": "第一个雷"
    },
    {
      "index": 14,
      "text": "动线没画"
    },
    {
      "index": 15,
      "text": "图纸上水景位置画得挺好"
    },
    {
      "index": 16,
      "text": "一出客厅正对着"
    },
    {
      "index": 17,
      "text": "但你顺着图纸走一遍"
    },
    {
      "index": 18,
      "text": "就发现问题了"
    },
    {
      "index": 19,
      "text": "人从客厅到水景"
    },
    {
      "index": 20,
      "text": "得绕过一片绿化带"
    },
    {
      "index": 21,
      "text": "下雨天你穿个拖鞋过去"
    },
    {
      "index": 22,
      "text": "踩一脚泥"
    },
    {
      "index": 23,
      "text": "这什么意思"
    },
    {
      "index": 24,
      "text": "做完了一定会改"
    },
    {
      "index": 25,
      "text": "加条汀步路"
    },
    {
      "index": 26,
      "text": "拆了草皮铺石板"
    },
    {
      "index": 27,
      "text": "管线绕开走"
    },
    {
      "index": 28,
      "text": "多花一笔钱"
    },
    {
      "index": 29,
      "text": "这钱要花吗"
    },
    {
      "index": 30,
      "text": "设计的时候拿支笔"
    },
    {
      "index": 31,
      "text": "把动线画出来"
    },
    {
      "index": 32,
      "text": "这事儿就省了"
    },
    {
      "index": 33,
      "text": "第二个雷"
    },
    {
      "index": 34,
      "text": "隐蔽工程只标了有"
    },
    {
      "index": 35,
      "text": "没标怎么修"
    },
    {
      "index": 36,
      "text": "泵坑在图纸上就是一个方块"
    },
    {
      "index": 37,
      "text": "写俩字循环泵"
    },
    {
      "index": 38,
      "text": "但泵坑检修口留多大"
    },
    {
      "index": 39,
      "text": "朝哪边开"
    },
    {
      "index": 40,
      "text": "管子是活结还是胶粘"
    },
    {
      "index": 41,
      "text": "这些图纸上一个字都没有"
    },
    {
      "index": 42,
      "text": "施工队怎么干"
    },
    {
      "index": 43,
      "text": "怎么省事怎么来"
    },
    {
      "index": 44,
      "text": "管子胶粘粘死检修口"
    },
    {
      "index": 45,
      "text": "留三十公分"
    },
    {
      "index": 46,
      "text": "两年后泵一坏"
    },
    {
      "index": 47,
      "text": "手伸不进去"
    },
    {
      "index": 48,
      "text": "得砸池壁砸了重修"
    },
    {
      "index": 49,
      "text": "五位数起步"
    },
    {
      "index": 50,
      "text": "五年后修泵的人怎么站"
    },
    {
      "index": 51,
      "text": "手往哪伸"
    },
    {
      "index": 52,
      "text": "这笔钱根本不用花"
    },
    {
      "index": 53,
      "text": "第三个雷"
    },
    {
      "index": 54,
      "text": "也是最坑的"
    },
    {
      "index": 55,
      "text": "树种写了尺寸没写"
    },
    {
      "index": 56,
      "text": "图纸上标的"
    },
    {
      "index": 57,
      "text": "红枫×3"
    },
    {
      "index": 58,
      "text": "元宝枫×2"
    },
    {
      "index": 59,
      "text": "光看了文字没问题"
    },
    {
      "index": 60,
      "text": "但你查一下"
    },
    {
      "index": 61,
      "text": "成年冠幅就毛了"
    },
    {
      "index": 62,
      "text": "元宝枫长开了"
    },
    {
      "index": 63,
      "text": "冠幅七八米"
    },
    {
      "index": 64,
      "text": "按现在的间距"
    },
    {
      "index": 65,
      "text": "种下去三年后"
    },
    {
      "index": 66,
      "text": "树冠打架"
    },
    {
      "index": 67,
      "text": "把水景的光全遮住了"
    },
    {
      "index": 68,
      "text": "最后怎么办"
    },
    {
      "index": 69,
      "text": "挖了两棵重新排"
    },
    {
      "index": 70,
      "text": "又打进去一笔"
    },
    {
      "index": 71,
      "text": "三个雷加起来好几万"
    },
    {
      "index": 72,
      "text": "图纸八万落地十一万出头"
    },
    {
      "index": 73,
      "text": "多出来的钱"
    },
    {
      "index": 74,
      "text": "不是材料长了"
    },
    {
      "index": 75,
      "text": "不是施工队坑了"
    },
    {
      "index": 76,
      "text": "是图纸上那些没画的东西"
    },
    {
      "index": 77,
      "text": "动线检修口"
    },
    {
      "index": 78,
      "text": "树长多大"
    },
    {
      "index": 79,
      "text": "好图纸不只是告诉你做什么"
    },
    {
      "index": 80,
      "text": "是告诉你"
    },
    {
      "index": 81,
      "text": "做了之后不后悔"
    },
    {
      "index": 82,
      "text": "施工前花一天审图"
    },
    {
      "index": 83,
      "text": "施工后少花几万改错"
    },
    {
      "index": 84,
      "text": "觉得有用吗"
    },
    {
      "index": 85,
      "text": "收藏这一期"
    },
    {
      "index": 86,
      "text": "做院子之前翻出来看眼"
    },
    {
      "index": 87,
      "text": "下期更狠"
    },
    {
      "index": 88,
      "text": "施工队最怕你看懂的三个图纸细节"
    },
    {
      "index": 89,
      "text": "关注我别错过"
    }
  ]
}